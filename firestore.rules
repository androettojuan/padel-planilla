rules_version = '2';

// Acceso restringido por allowlist: solo entran los usuarios cuyo email esté
// en la colección `allowlist` (administrada por el dueño desde la consola).
// La allowlist no se puede escribir desde el cliente, así que "desactivar la
// creación de cuentas" es simplemente no agregar más emails.
service cloud.firestore {
  match /databases/{database}/documents {
    function isAllowed() {
      return request.auth != null
        && exists(/databases/$(database)/documents/allowlist/$(request.auth.token.email));
    }

    match /config/{doc} {
      allow read, write: if isAllowed();
    }

    match /planillas/{doc} {
      allow read, write: if isAllowed();
    }

    match /jugadores/{doc} {
      allow read, write: if isAllowed();
    }

    match /fiadoPagos/{doc} {
      allow read, write: if isAllowed();
    }

    match /fiadoCargos/{doc} {
      allow read, write: if isAllowed();
    }

    match /fiadoCortes/{doc} {
      allow read, write: if isAllowed();
    }

    // Cada usuario puede consultar solo su propia entrada (para saber si está
    // habilitado). El alta/baja se hace desde la consola, nunca desde la app.
    match /allowlist/{email} {
      allow read: if request.auth != null && request.auth.token.email == email;
      allow write: if false;
    }
  }
}
